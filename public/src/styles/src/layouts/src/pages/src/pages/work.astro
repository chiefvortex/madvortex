---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";

const projects = [
  {
    title: "Nothing Phone",
    description: "Directorial debut. TV commercial airing on GEO, Hotstar nationwide.",
    tag: "Director",
  },
  {
    title: "Virat Kohli",
    description: "Directed. Major brand film production.",
    tag: "Director",
  },
  {
    title: "Air One",
    description: "Technical showcase. VFX, color, everything.",
    tag: "VFX / Color",
  },
  {
    title: "RCB x Qatar Airways",
    description: "Brand campaign.",
    tag: "Production",
  },
  {
    title: "Nike",
    description: "Brand collaboration.",
    tag: "Brand",
  },
  {
    title: "Spotify",
    description: "Creative production.",
    tag: "Brand",
  },
  {
    title: "IKEA",
    description: "Brand work.",
    tag: "Brand",
  },
  {
    title: "Converse",
    description: "Brand collaboration.",
    tag: "Brand",
  },
];
---

<BaseLayout title="Work — Naveen Kumar" description="Selected projects by Naveen Kumar. Director, VFX, AI production.">
  <section class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-4 fade-in">Work</h1>
    <p class="text-muted mb-16 fade-in fade-in-delay-1">Selected projects.</p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((project, i) => (
        <article
          class={`group relative rounded-xl border border-white/5 bg-white/[0.02] p-6 hover:bg-white/[0.04] hover:border-white/10 transition-all duration-300 fade-in fade-in-delay-${Math.min(i + 1, 4)}`}
        >
          <div class="aspect-[16/9] rounded-lg bg-gradient-to-br from-white/[0.03] to-transparent mb-5" />
          <div class="flex items-start justify-between gap-2">
            <div>
              <h2 class="font-semibold text-lg tracking-tight group-hover:text-white transition-colors">
                {project.title}
              </h2>
              <p class="text-sm text-muted mt-1 leading-relaxed">{project.description}</p>
            </div>
            <span class="text-xs text-muted/60 border border-white/5 rounded-full px-2.5 py-0.5 whitespace-nowrap mt-1">
              {project.tag}
            </span>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>