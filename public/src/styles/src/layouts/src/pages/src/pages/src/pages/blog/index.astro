---
import BaseLayout from "../../layouts/BaseLayout.astro";
import "../../styles/global.css";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf()
);
---

<BaseLayout title="Blog — Naveen Kumar" description="Thoughts on AI filmmaking, production, and technology.">
  <section class="max-w-3xl mx-auto px-6 py-24">
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight mb-4 fade-in">Blog</h1>
    <p class="text-muted mb-16 fade-in fade-in-delay-1">Writing about AI, filmmaking, and production.</p>

    <div class="space-y-1">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.slug}`}
          class={`block group py-5 border-b border-white/5 hover:bg-white/[0.02] -mx-4 px-4 rounded-lg transition-all fade-in fade-in-delay-${Math.min(i + 1, 4)}`}
        >
          <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
            <h2 class="font-medium text-lg tracking-tight group-hover:text-white transition-colors">
              {post.data.title}
            </h2>
            <time
              datetime={new Date(post.data.pubDate).toISOString()}
              class="text-sm text-muted whitespace-nowrap"
            >
              {new Date(post.data.pubDate).toLocaleDateString("en-US", {
                year: "numeric",
                month: "short",
                day: "numeric",
              })}
            </time>
          </div>
          <p class="text-sm text-muted mt-1">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>