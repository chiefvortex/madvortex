---
interface Props { title: string; description?: string; ogImage?: string; }
const { title, description = "Naveen Kumar — Director. AI production infrastructure. Vortex Labs & Vortex Films.", ogImage = "/og.png" } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0" />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="canonical" href={canonicalURL} />
<title>{title}</title>
<meta name="description" content={description} />
<meta name="author" content="Naveen Kumar" />
<meta property="og:type" content="website" />
<meta property="og:url" content={canonicalURL} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={new URL(ogImage, Astro.site)} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:site" content="@madvortex_" />
<meta name="twitter:creator" content="@madvortex_" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={new URL(ogImage, Astro.site)} />
<link rel="alternate" type="application/rss+xml" title="Naveen Kumar — Blog" href="/rss.xml" />
</head>
<body class="min-h-screen bg-bg text-text antialiased">
<nav class="fixed top-0 left-0 right-0 z-50 bg-bg/80 backdrop-blur-md border-b border-white/5">
<div class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
<a href="/" class="text-sm font-semibold tracking-tight hover:opacity-70 transition-opacity">NK</a>
<div class="flex gap-6 text-sm text-muted">
<a href="/work" class="hover:text-text transition-colors">Work</a>
<a href="/blog" class="hover:text-text transition-colors">Blog</a>
</div></div></nav>
<main class="pt-16"><slot /></main>
<footer class="border-t border-white/5 mt-32">
<div class="max-w-3xl mx-auto px-6 py-12 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm text-muted">
<span>&copy; {new Date().getFullYear()} Naveen Kumar</span>
<div class="flex gap-6">
<a href="https://twitter.com/madvortex_" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">Twitter</a>
<a href="https://instagram.com/madvortex_" target="_blank" rel="noopener noreferrer" class="hover:text-text transition-colors">Instagram</a>
</div></div></footer>
</body></html>