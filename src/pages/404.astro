---
import BaseLayout from "../layouts/BaseLayout.astro";
import "../styles/global.css";
---
<BaseLayout title="404 — Naveen Kumar" description="Page not found.">
  <section class="min-h-[calc(100vh-4rem)] flex flex-col items-center justify-center max-w-3xl mx-auto px-6">
    <p class="text-muted text-sm tracking-widest uppercase mb-4 fade-in">404</p>
    <h1 class="text-3xl sm:text-4xl font-semibold tracking-tight fade-in fade-in-delay-1">Page not found</h1>
    <p class="text-muted mt-3 fade-in fade-in-delay-2">The page you're looking for doesn't exist.</p>
    <a href="/" class="mt-8 text-sm text-muted hover:text-text transition-colors fade-in fade-in-delay-3">&larr; Back home</a>
  </section>
</BaseLayout>
